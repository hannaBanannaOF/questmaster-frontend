{
  "name": "questmaster-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:light": "next dev",
    "dev": "concurrently -n \"NEXT,TS\" -c \"cyan,magenta\" \"next dev\" \"yarn typecheck:watch\"",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "eslint . --cache",
    "lint:watch": "chokidar \"**/*.{ts,tsx,js,jsx}\" -c \"eslint . --cache\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "next build",
    "start": "next start"
  },
  "dependencies": {
    "@tanstack/react-query": "5.52.1",
    "@tanstack/react-query-devtools": "5.52.2",
    "@tanstack/react-query-next-experimental": "5.52.2",
    "dayjs": "1.11.13",
    "lucide-react": "^1.7.0",
    "next": "16.0.0",
    "next-intl": "4.4.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "shimmer-from-structure": "^2.4.2",
    "styled-components": "^6.3.12",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@tanstack/eslint-plugin-query": "^5.95.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/parser": "^5.0.1",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.1.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  }
}
